# Copy to `.env.local` and fill in values.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: used for reliable Pro subscribe/cancel (Supabase → Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_NAME=Teach smart

# Optional: comma-separated emails that always get `admin` in `public.users` on profile sync.
# Example: NEXT_PUBLIC_ADMIN_EMAILS=admin@school.edu,superuser@school.edu
NEXT_PUBLIC_ADMIN_EMAILS=

# AI (see /setup)
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Pro subscription (demo payment gateway — no real processor)
# NEXT_PUBLIC_PRO_PRICE=9.99
# NEXT_PUBLIC_PRO_CURRENCY=USD
# Optional: require a school code at checkout (set both)
# SUBSCRIBE_PROMO_CODE=school-pro-2026
# NEXT_PUBLIC_SUBSCRIBE_REQUIRES_CODE=true
